{
  "backend": {
    "name": "github",
    "repo": "cryptowebbuild/CryptoWebBuild-",
    "branch": "main"
  },
  "site_url": "https://cryptowebbuild.pages.dev",
  "collections": [
    {
      "name": "blog",
      "label": "Blog Posts",
      "match": "post-*.html",
      "format": "html",
      "extension": "html",
      "create": true,
      "fields": [
        {"name":"title","label":"Title","widget":"string"},
        {"name":"description","label":"Description","widget":"string","required": false},
        {"name":"body","label":"Body","widget":"markdown","required": false}
      ]
    }
  ]
}
